FROM ultralytics/ultralytics:latest-jetson-jetpack6

# ----------------------------------------------------
# 🧩 1. 修正 DNS（防止解析錯誤）
# ----------------------------------------------------
# RUN echo "nameserver 8.8.8.8" > /etc/resolv.conf

# ----------------------------------------------------
# 🧹 2. 移除舊版 NVIDIA repo
# ----------------------------------------------------
#RUN rm -f /etc/apt/sources.list.d/cuda.list \
#    && rm -f /etc/apt/sources.list.d/nvidia-l4t-apt-source.list

# ----------------------------------------------------
# 🔑 3. 匯入新版 NVIDIA GPG key
# ----------------------------------------------------
#RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates curl gnupg \
#    && curl -fsSL https://repo.download.nvidia.com/jetson/jetson-ota-public.asc | gpg --dearmor -o /usr/share/keyrings/nvidia-jetson.gpg \
#    && curl -fsSL https://developer.download.nvidia.com/compute/cuda/repos/ubuntu2204/sbsa/3bf863cc.pub | gpg --dearmor -o /usr/share/keyrings/cuda-archive-keyring.gpg

# ----------------------------------------------------
# 🌐 4. 設定新的 NVIDIA + CUDA + Ubuntu repo
# ----------------------------------------------------
#RUN echo "deb [signed-by=/usr/share/keyrings/cuda-archive-keyring.gpg] https://developer.download.nvidia.com/compute/cuda/repos/ubuntu2204/sbsa/ /" > /etc/apt/sources.list.d/cuda.list \
#    && echo "deb [signed-by=/usr/share/keyrings/nvidia-jetson.gpg] https://repo.download.nvidia.com/jetson/common r36.6 main" > /etc/apt/sources.list.d/nvidia-l4t-apt-source.list \
#    && echo "deb [signed-by=/usr/share/keyrings/nvidia-jetson.gpg] https://repo.download.nvidia.com/jetson/t234 r36.6 main" >> /etc/apt/sources.list.d/nvidia-l4t-apt-source.list \
#    && echo "deb [signed-by=/usr/share/keyrings/nvidia-jetson.gpg] https://repo.download.nvidia.com/jetson/ffmpeg r36.6 main" >> /etc/apt/sources.list.d/nvidia-l4t-apt-source.list \
#    && echo "deb http://ports.ubuntu.com/ubuntu-ports jammy main universe multiverse restricted" > /etc/apt/sources.list


# ----------------------------------------------------
# ⚙️ 重新匯入 NVIDIA Jetson L4T repo 與 GPG key
# ----------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates curl gnupg && \
    curl -fsSL https://repo.download.nvidia.com/jetson/jetson-ota-public.asc \
      | gpg --dearmor -o /usr/share/keyrings/nvidia-jetson.gpg && \
    echo "deb [signed-by=/usr/share/keyrings/nvidia-jetson.gpg] https://repo.download.nvidia.com/jetson/common r36.2 main" > /etc/apt/sources.list.d/nvidia-l4t-apt-source.list && \
    echo "deb [signed-by=/usr/share/keyrings/nvidia-jetson.gpg] https://repo.download.nvidia.com/jetson/t234 r36.2 main" >> /etc/apt/sources.list.d/nvidia-l4t-apt-source.list


# 移除無法在 Docker 內連線的 NVIDIA apt sources
RUN rm -f /etc/apt/sources.list.d/nvidia-l4t*.list \
    && rm -f /etc/apt/sources.list.d/cuda*.list \
    && rm -f /etc/apt/sources.list.d/jetson*.list


# ----------------------------------------------------
# 🚀 5. 更新系統並安裝 CUDA + GStreamer
# ----------------------------------------------------

RUN echo "deb http://ports.ubuntu.com/ubuntu-ports jammy main restricted universe multiverse" > /etc/apt/sources.list && \
    echo "deb http://ports.ubuntu.com/ubuntu-ports jammy-updates main restricted universe multiverse" >> /etc/apt/sources.list && \
    echo "deb http://ports.ubuntu.com/ubuntu-ports jammy-security main restricted universe multiverse" >> /etc/apt/sources.list && \
    echo "deb http://ports.ubuntu.com/ubuntu-ports jammy-backports main restricted universe multiverse" >> /etc/apt/sources.list && \
    apt-get clean


# ======================================================
# System utilities (for debugging, networking, editing)
# ======================================================
RUN apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    iproute2 \
    net-tools \
    iputils-ping \
    dnsutils \
    curl \
    wget \
    less \
    vim \
    nano \
 && apt-get clean && rm -rf /var/lib/apt/lists/*
# ======================================================
# GStreamer core components
# ======================================================
RUN apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    gstreamer1.0-tools \
    gstreamer1.0-plugins-base \
    gstreamer1.0-plugins-good \
    gstreamer1.0-plugins-bad \
    gstreamer1.0-plugins-ugly \
    gstreamer1.0-libav \
    gstreamer1.0-gl \
 && apt-get clean && rm -rf /var/lib/apt/lists/*

# ======================================================
# Python + OpenCV (no GUI)
# ======================================================
RUN apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    python3-opencv \
    libopencv-videoio-dev \
 && apt-get clean && rm -rf /var/lib/apt/lists/*

# ======================================================
# Optional: Python GStreamer bindings (for gst-python)
# ======================================================
RUN apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    python3-gi \
    gir1.2-gstreamer-1.0 \
 && apt-get clean && rm -rf /var/lib/apt/lists/*

# ----------------------------------------------------
# 📂 6. 放入 YOLO 模型與程式
# ----------------------------------------------------
WORKDIR /workspace

CMD ["python3", "main.py"]

