import socket
import json
from threading import Thread

from packet import packet_builder

model = YOLO("yolo11n.pt")
output_fps = 30
frame_duration = 1 / output_fps * Gst.SECOND  # 30fps
frame_count = 0
start_time = 0;

lock_id = -1
lock_xyxy = []
locked = False

def draw_custom(results, frame):
    

    """
    自訂繪製 YOLOv11 tracking 結果在影像上。
    Args:
        results: YOLOv11 的輸出 (model.track 或 model.predict)
        frame: 原始影像 (BGR numpy array)
    Returns:
        繪製後影像 (BGR)
    """
    global lock_id, lock_xyxy, locked

    boxes = results[0].boxes
    xyxy = boxes.xyxy.cpu().numpy()         # [x1, y1, x2, y2]
    confs = boxes.conf.cpu().numpy()
    clss = boxes.cls.cpu().numpy().astype(int)
    ids = boxes.id.cpu().numpy().astype(int) if boxes.id is not None else [None] * len(xyxy)
    
    if lock_id in ids:
        locked = True
    else:
        locked = False

    height, width = frame.shape[:2]
    for i in range(len(xyxy)):
        x1, y1, x2, y2 = map(int, xyxy[i])
        conf = confs[i]
        cls = clss[i]
        obj_id = ids[i] if ids[i] is not None else -1

        color = (0, 255, 0)

        if lock_id == obj_id:
            color = (0, 0, 255)
            lock_xyxy = [(x1+x2)/2/width,(y1+y2)/2/height]
            print(f"x,y:{lock_xyxy}")


        label = f"ID:{obj_id} {results[0].names[cls]} {conf:.2f}"

        # 繪製邊框與標籤
        cv2.rectangle(frame, (x1, y1), (x2, y2), color, 2)
        cv2.putText(frame, label, (x1, y1 - 10),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.5, color, 2, cv2.LINE_AA)

    return frame

def detections_to_json(results):
    """
    Convert YOLOv11 tracking results to JSON format with xyxy coordinates.

    Args:
        results: YOLOv11 tracking output (model.track or model.predict)

    Returns:
        JSON string, e.g.
        [
          {"id":1,"class":0,"conf":0.88,"x1":100,"y1":150,"x2":200,"y2":300},
          {"id":2,"class":2,"conf":0.92,"x1":400,"y1":220,"x2":520,"y2":350}
        ]
    """
    if not results or len(results) == 0 or results[0].boxes is None:
        return "[]"

    boxes = results[0].boxes

    xyxy = boxes.xyxy.cpu().numpy()             # [[x1, y1, x2, y2], ...]
    ids = boxes.id.cpu().numpy().astype(int) if boxes.id is not None else [None] * len(xyxy)
    classes = boxes.cls.cpu().numpy().astype(int)
    confs = boxes.conf.cpu().numpy()

    detections = []
    for i in range(len(xyxy)):
        x1, y1, x2, y2 = xyxy[i]
        detections.append({
            "id": int(ids[i]) if ids[i] is not None else None,
            "class": int(classes[i]),
            "conf": float(confs[i]),
            "x1": float(x1),
            "y1": float(y1),
            "x2": float(x2),
            "y2": float(y2)
        })

    return json.dumps(detections)

def extract_frame_from_sample(sample):
    """GStreamer sample -> NumPy frame"""
    buf = sample.get_buffer()
    caps = sample.get_caps().get_structure(0)
    width = caps.get_value("width")
    height = caps.get_value("height")

    success, map_info = buf.map(Gst.MapFlags.READ)
    if not success:
        return None
    try:
        frame = np.frombuffer(map_info.data, np.uint8).reshape((height, width, 4))
    finally:
        buf.unmap(map_info)
    return frame

def on_new_sample(sink):
    
    in_start_time = time.time()

    #global model
    global frame_duration
    global frame_count
    global appsrc
    global start_time
    """拉一幀並顯示"""
    while True:
        tmp = sink.emit("try-pull-sample", 0)
        
        if tmp is None:
            break
        sample = tmp
    
   
    frame = extract_frame_from_sample(sample)

    if frame is not None:
        frame_bgr = cv2.cvtColor(frame, cv2.COLOR_RGBA2BGR)
        resized_frame = cv2.resize(frame_bgr, (720, 480))
        resized_frame = resized_frame[:,:,:3]
        
        
        results = model.track(resized_frame,persist=True, verbose=False,classes=[0,2])
        print(detections_to_json(results))
        annotated = draw_custom(results,resized_frame)
        #annotated = results[0].plot()


        
        now = time.localtime()
        timestamp = time.strftime("%M:%S", now)

        #cv2.putText(resized_frame, f"Time: {timestamp}", (10, 30),cv2.FONT_HERSHEY_SIMPLEX, 1, (0, 255, 0), 2)
        
        now = time.time()
        localtime = time.localtime(now)
        timestamp = time.strftime("%M:%S", localtime)
        milliseconds = int((now % 1) * 1000)

        filename = f"record/frame_{int(now)}_{timestamp}.{milliseconds:03d}.jpg"


        data = annotated.tobytes()
        buf = Gst.Buffer.new_allocate(None, len(data), None)
        buf.fill(0, data)
        
        buf.pts = buf.dts = int(frame_count * frame_duration)
        buf.duration = int(frame_duration)
        
        
        '''
        original_buffer = sample.get_buffer()
        buf.pts = original_buffer.pts
        buf.dts = original_buffer.dts
        buf.duration = original_buffer.duration
        '''
        retval = appsrc.emit("push-buffer", buf)
        if retval != Gst.FlowReturn.OK:
            print("❌ 推送失敗", retval)
        
        frame_count += 1
        end_time = time.time()
        in_end_time = time.time()
        fps = 1/(end_time - start_time)
        handle_time = in_end_time - in_start_time
        start_time = end_time
        print(f"output fps：{fps:.1f}  frame handle time: {handle_time:.4f}")

    return Gst.FlowReturn.OK

class rtsp_pipline:
    def __init__(self, rtsp_src_url):
        self.pipeline_str = (
        f"rtspsrc location={rtsp_src_url} latency=100 ! "
        "rtph264depay ! h264parse ! nvv4l2decoder ! "
        "nvvidconv ! video/x-raw, format=RGBA ! "
        "videorate ! video/x-raw, framerate=10/1 ! "
        "tee name=t "
        "t. ! queue ! appsink name=mysink emit-signals=true sync=false max-buffers=1 drop=true "
        #"t. ! queue ! nveglglessink sync=false"
        )
        self.lasttime = time.time()
        self._parsePipeline()
    def _parsePipeline(self):
        self.pipeline = Gst.parse_launch(self.pipeline_str)
        self.appsink = self.pipeline.get_by_name("mysink")
        
        #appsink.set_property("emit-signals", True)
        #appsink.set_property("sync", False)
        #appsink.set_property("max-buffers", 1)
        #appsink.set_property("drop", True)
        #appsink.set_property("enable-last-sample", False)
        #appsink.set_property("wait-on-eos", False)
        
        self.appsink.connect("new-sample", on_new_sample)
        
        # 監聽 bus 訊息
        bus = self.pipeline.get_bus()
        bus.add_signal_watch()
        bus.connect("message", self.on_bus_message)
        
        pass
    def setStart(self):
        if self.pipeline != None:
            self.pipeline.set_state(Gst.State.PLAYING)
        else:
            print("pipeline not init")
    def setNull(self):
        if self.pipeline != None:
            self.pipeline.set_state(Gst.State.NULL)
            del self.pipeline
        else:
            print("pipeline not init")
    def schedule_reconnect(self):
        if (time.time() - self.lasttime > 10):
            self.setNull()
            self.parsePipeline()
            self.setStart()
            self.lasttime = time.time()
            print("reconnect")
    def on_bus_message(self, bus, message):
        msg_type = message.type
        print(f"{msg_type}")
        if msg_type == Gst.MessageType.ERROR:
            err, debug = message.parse_error()
            print(f"❌ GStreamer Error: {err}, {debug}")
            self.schedule_reconnect()

        elif msg_type == Gst.MessageType.EOS:
            print("📴 End of stream (EOS)")
            self.schedule_reconnect()


class udp_pipline:
    def __init__(self, udp_sink_ip,udp_sink_port,output_fps):
        self.pipeline_str = (
        "appsrc name=mysrc ! videoconvert ! "
        "x264enc tune=zerolatency bitrate=2000 speed-preset=superfast ! "
        "rtph264pay config-interval=1 pt=96 ! "
        f"udpsink host={udp_sink_ip} port={udp_sink_port}"
        )
        self.lasttime = time.time()
        self._parsePipeline()
    def _parsePipeline(self):
        self.pipeline = Gst.parse_launch(self.pipeline_str)
        self.appsrc = self.pipeline.get_by_name("mysrc")
        caps = Gst.Caps.from_string(f"video/x-raw,format=BGR,width=720,height=480,framerate={output_fps:.0f}/1")
        self.appsrc.set_property("caps", caps)
        self.appsrc.set_property("format", Gst.Format.TIME)
    def setStart(self):
        if self.pipeline != None:
            self.pipeline.set_state(Gst.State.PLAYING)
        else:
            print("pipeline not init")

class AI_Control_Server:
    def __init__(self, ip="0.0.0.0", port=5000):
        self.sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        self.sock.bind((ip, port))
        print(f"✅ Listening on {ip}:{port}")

    def handle_command(self, data, addr):
        global lock_id;
        try:
            cmd = json.loads(data.decode())
            action = cmd.get("action", "")
            params = cmd.get("params", {})

            print(f"📩 Command from {addr}: {action}, params={params}")

            if action == "lock":
                lock_id = params 
                response = {"status": "ok", "message": f"lock {params}"}
            elif action == "stop":
                response = {"status": "ok", "message": "AI stopped"}
            elif action == "set_param":
                response = {"status": "ok", "message": f"Set {params}"}
            else:
                response = {"status": "error", "message": "Unknown command"}

        except Exception as e:
            response = {"status": "error", "message": str(e)}

        self.sock.sendto(json.dumps(response).encode(), addr)

    def run(self):
        while True:
            data, addr = self.sock.recvfrom(4096)
            self.handle_command(data, addr)

def send_command(sock,DATA):
    print(f"Sent {len(DATA)} bytes:", DATA.hex(" "))
    sock.sendall(DATA)

def server_gimbal():
    global lock_xyxy, locked
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    HOST = "192.168.144.64"
    PORT = 8888
    print(f"Connecting to {HOST}:{PORT} ...")
    sock.connect((HOST, PORT))

    while True:
        if (locked == False):
            send_command(sock, packet_builder.do_center())
            time.sleep(0.1)
            continue


        x_ratio = lock_xyxy[0]
        y_ratio = lock_xyxy[1]

        dead_zone = 0.1  # 容許範圍寬度 (0.5 ± 0.1 → 0.4~0.6)
        center = 0.5

        x_offset = x_ratio - center
        y_offset = y_ratio - center

        # 初始化指令
        pan = 0
        tilt = 0

        # ---- X 軸控制 (左右) ----
        if abs(x_offset) > dead_zone:
            if x_offset < 0:  # 在畫面左邊
                pan = -64
                print("👈 向左轉")
            else:              # 在畫面右邊
                pan = 64
                print("👉 向右轉")

        # ---- Y 軸控制 (上下) ----
        if abs(y_offset) > dead_zone:
            if y_offset < 0:  # 在畫面上方
                tilt = 64
                print("👆 向上轉")
            else:              # 在畫面下方
                tilt = -64
                print("👇 向下轉")

        # ---- 發送控制指令 ----
        if pan != 0 or tilt != 0:
            send_command(sock, packet_builder.do_joystick(pan, tilt))
        else:
            print("🟡 目標在中心，不移動")
        time.sleep(0.1)





def ai_gimbal():

    global loop
    global appsrc
    global output_fps
    Gst.init(None)
    
    # load config
    with open("rtsp_config.yaml", "r") as f:
        config = yaml.safe_load(f)
    print("===config===")
    for key, value in config.items():
        print(f"{key}: {value}")
    
    # 1. 建立 2 個gstreamer pipeline 與 1 個AI 推論服務
    
    # input rtsp stream
    rtsp_handler = rtsp_pipline(config["rtsp_src"])
    # ouput udp stream
    udp_stream_handler = udp_pipline(config['udp_sink_ip'],config['udp_sink_port'],output_fps)
    
    # AI result ouput to appsrc
    appsrc = udp_stream_handler.appsrc
    
    # set playing
    rtsp_handler.setStart()
    udp_stream_handler.setStart()

    
    
    # 雲台控制 server
    ai_control_server = AI_Control_Server(port=config['udp_sink_port'])
    thread = Thread(target=ai_control_server.run, daemon=True)
    
    # 雲台控制
    thread_gimbal = Thread(target=server_gimbal, daemon=True)

    thread.start()
    thread_gimbal.start()
    
    # Gstreamer event loop
    loop = GLib.MainLoop()
    try:
        loop.run()
    except KeyboardInterrupt:
        pass
    finally:
        pass







if __name__ == "__main__":
    main()
